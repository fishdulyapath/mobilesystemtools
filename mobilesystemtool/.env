VITE_API_BASE_URL=/service/v1
VITE_BASKET_COUNT=100


# Dev only: where vite dev server proxies /service/* to (default http://localhost:47300)
VITE_DEV_PROXY_TARGET=http://localhost:47307

# Dev only: ตั้ง true เพื่อจำลองการชำระเงิน Tiger โดยไม่ยิง API จริง (auto-success ใน ~5 วินาที)
VITE_TIGER_MOCK=false

# Dev only: ตั้ง true เพื่อแสดงปุ่ม mock รายการรอรับชำระ Tiger ว่าจ่ายแล้ว
VITE_TIGER_PENDING_MOCK=false
PURCHASE_PU_SAVE_ENABLED=true
VITE_SALE_DOCUMENT_TYPES=sale,sale_order,reserve_order
